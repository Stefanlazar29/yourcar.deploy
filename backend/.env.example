# Copiază ca backend/.env
# JWT: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=schimba-ma-cu-hex-64-caractere-generat
# EXO / chat: Groq (recomandat). Fallback Ollama local dacă Groq eșuează sau AI_USE_LOCAL_ONLY=1
# Dacă lipsește sau e gol → ai_proxy ridică RuntimeError("GROQ_API_KEY lipsește") și /assistant/exo nu răspunde.
GROQ_API_KEY=
# Model chat rapid — implicit în cod: llama-3.1-8b-instant (cote mai relaxate; evită 429 vs. 70B)
GROQ_MODEL_FAST=llama-3.1-8b-instant
# Alte opțiuni (OpenAI-compatible):
# GROQ_MODEL_STRUCTURED=...
# GROQ_MODEL_FAST=llama-3.3-70b-versatile
# Test UI/scroll fără consum Groq: MULBERRY_EXO_MOCK=1 (opțional MULBERRY_EXO_MOCK_TEXT=...)
# MULBERRY_EXO_MOCK=0
# RAG în prompt: fragment Chroma scurt; dezactivare completă: MULBERRY_RAG_INJECT_CHROMA=0
# Chat MulberryEXO: Gemini (Google AI) sau Groq — setează AI_CHAT_PROVIDER=gemini|groq
# GEMINI_API_KEY=
# GOOGLE_API_KEY=   (alias acceptat)
# AI_CHAT_PROVIDER=gemini
# GEMINI_MODEL=gemini-2.0-flash
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3
# AI_USE_LOCAL_ONLY=0
# MiniMax doar dacă MINIMAX_FORCE=1 (legacy)
MINIMAX_API_KEY=sk-api-REPLACE_ME
# Politică un dispozitiv: trimite X-Mulberry-Device-Id din client; deblocare nou dispozitiv: POST /auth/device/approve
# Pentru Hub/dev fără verificare strictă dispozitiv: 0 sau gol. Producție cu un singur dispozitiv: 1
MULBERRY_SINGLE_DEVICE=0
# Semnătură dispozitiv în rapoarte arhivă (opțional)
# ARCHIVE_DEVICE_HWID=
AGENT_ID=MulberryEXO

# Intel piață model (Škoda Fabia 6Y): Wikipedia API + sinteză Groq în SQLite; scheduler APScheduler
# MARKET_INTEL_DISABLE=1 — nu rula job-ul
# MARKET_INTEL_INTERVAL_HOURS=24 — interval reîmprospătare (min 6, max 168)
# MARKET_INTEL_BOOT_SEC=120 — primul ciclu după pornirea serverului

# SoftScore · fișiere interne piață (Autovit + verificare Groq), max o dată la N ore per model
# SOFTSCORE_MARKET_GROQ=1 — 0 dezactivează scrierea snapshot-urilor
# SOFTSCORE_MARKET_INTERVAL_HOURS=24 — același interval ca job scheduler + cache
# SOFTSCORE_MARKET_BOOT_SEC=180 — primul ciclu snapshot după boot server

# MLBR Digital File (HMAC) — nu folosi în producție valoarea implicită
MLBR_SECRET=schimba-cu-secret-puternic-min-32-chars
# URL de bază în payload (verify_url în JSON); QR în frontend folosește apiBase + mlbr_file.html
MLBR_PUBLIC_BASE=https://id.mulberry.ro
