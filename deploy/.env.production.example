# Copiază în rădăcina proiectului ca `.env` pentru `docker compose up`.
# Nu comita `.env` în git.

# --- Obligatoriu în producție (schimbă valorile!) ---
JWT_SECRET=înlocuiește-cu-minim-32-caractere-aleatorii
MLBR_SECRET=alt-secret-puternic-pentru-semnături-MLBR

# CORS: domeniul public HTTPS al aplicației (fără slash final)
MULBERRY_CORS_ORIGINS=https://mulberry.exemplu.ro

# Opțional: chei API (nu le pune în repo)
MINIMAX_API_KEY=
GROQ_API_KEY=
# Model implicit în cod: llama-3.1-8b-instant. Suprascrie dacă e nevoie:
# GROQ_MODEL_FAST=llama-3.1-8b-instant
# MULBERRY_EXO_MOCK=1 — răspuns fix fără Groq (doar dev/test UI)
TRAIN_SECRET=

# Public URL pentru link-uri MLBR în JSON
MLBR_PUBLIC_BASE=https://mulberry.exemplu.ro

# --- Backup S3 / DigitalOcean Spaces (opțional) ---
# Dacă setezi bucket, scriptul urcă copiile din /data/backups/
# S3_BACKUP_BUCKET=mulberry-backups
# S3_BACKUP_PREFIX=prod/sqlite
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-central-1
# Pentru DO Spaces:
# AWS_ENDPOINT_URL=https://fra1.digitaloceanspaces.com

# Interval backup (secunde)
BACKUP_INTERVAL_SEC=3600

# VACUUM săptămânal: ziua 0=luni … 6=duminică; goale = fără vacuum automat
VACUUM_WEEKLY_ON_DAY=0
# Sau o singură dată la următorul ciclu: RUN_VACUUM_NOW=1 (apoi scoate)

# Păstrează ultimele N backup-uri locale pe volum
BACKUP_KEEP_LOCAL=48
